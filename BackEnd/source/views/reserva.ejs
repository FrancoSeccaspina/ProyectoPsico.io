<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head.ejs') %>
    <title>Detalle de Reserva</title>
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>

<header>
    <%- include('partials/header.ejs') %>
</header>

<main class="contenedorConsulta">
    <div class="card-detalle">
        <section class="titulosPrincipal">
            <h1>Detalles de tu Sesión</h1>
            <p>Revisá la información de los servicios contratados.</p>
        </section>

        <table class="tabla-servicios">
            <thead>
                <tr>
                    <th>Servicio</th>
                    <th>Descripción</th>
                    <th>Duración</th>
                    <th>Precio</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof data !== 'undefined' && data.length > 0) { %>
                    <% let totalReserva = 0; %>
                    <% data.forEach(item => { %>
                        <% totalReserva += Number(item.precio); %>
                        <tr>
                            <td><strong><%= item.servicio %></strong></td>
                            <td><%= item.descripcion || 'Sin descripción' %></td>
                            <td><span class="badge-duracion"><%= item.duracion %> min</span></td>
                            <td>$<%= Number(item.precio).toLocaleString('es-AR') %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>

            <div class="total-box">
                Total a pagar: $<%= totalReserva.toLocaleString('es-AR') %>
            </div>
            
        <% } else { %>
            <div class="alert alert-info">
                No hay servicios cargados para esta reserva.
            </div>
        <% } %>

        <div style="margin-top: 2rem;">
            <a href="/primera-consulta" class="btn-reserva">Volver a Consultas</a>
        </div>
    </div>
</main>

<footer>
    <%- include('partials/footer.ejs') %>
</footer>

</body>
</html>