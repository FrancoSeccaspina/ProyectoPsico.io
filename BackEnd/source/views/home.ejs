<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head.ejs') %>

</head>

<body>

<header>

    <%- include('partials/header.ejs') %>

</header>

<main class="main-content">

    <!-- HERO -->
    <section class="hero-container">
        <div class="hero-text">
            <h1>Construyamos una vida en <span>calma</span></h1>
            <p>Tu lugar seguro para el cambio que necesitas.</p>
            <a href="/reservar" class="btn-start">¡QUIERO EMPEZAR!</a>
        </div>

        <div class="hero-image">
            <img src="/images/perfil.jpg" alt="Profesional">
            
            <div class="profile-card">
                <img src="/images/perfil_mini.jpg" alt="Miniatura">
                <div class="profile-info">
                    <h4><%= locals.nombre || "Lic. Natalia Ferri" %></h4>
                    <p>Psicóloga Clínica</p>
                </div>
            </div>
        </div>
    </section>

    <!-- TICKER -->
    <div class="ticker-container">
        <div class="ticker-wrapper">
            <div class="ticker-content">
                <% for(let i = 0; i < 6; i++) { %>
                    <span>Psicología para el bienestar personal</span>
                    <div class="ticker-line"></div>
                <% } %>
           </div>
        </div>
    </div>

    <!-- ABOUT -->
    <section class="about-section">
        <div class="about-container">

            <div class="about-image">
                <div class="circle-frame">
                    <img src="/images/perfil_mini.jpg" alt="perfil">
                </div>
            </div>

            <div class="about-content">
                <span class="section-subtitle">MI HISTORIA</span>
                <h2 class="section-title">¡Bienvenido!</h2>

                <p class="section-description">
                    Soy Natalia Ferri licenciada en psicología especializada en trastornos de ansiedad desde la terapia cognitivo conductual. 
                    Mi principal objetivo es ayudarte a gestionar la ansiedad para mejorar la calidad de tu vida.
                </p>

                <a href="/reservar" class="btn-reserve">RESERVAR</a>
            </div>

        </div>
    </section>

    <!-- SERVICIOS -->
    <section class="container">
        <h2 class="title">¿Qué encontrás en Psico Mente?</h2>
        
        <div class="grid">

            <div class="card">
                <div class="card-image">
                    <img src="/images/img_sentada.png" alt="Sesiones">
                    <div class="caption top-left">
                        <h3>Sesiones</h3>
                        <p>personalizadas</p>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image">
                    <img src="/images/img_sentada.png" alt="Blog">
                    <div class="caption-blog">Mi <i>Blog</i></div>
                </div>
            </div>

        </div>

        <section class="scrolling-text">
            <span>PISCO.MENTE - PISCO.MENTE - PISCO.MENTE - PISCO.MENTE</span>
        </section>
    </section>

    <!-- FOOTER -->
    <footer class="main-footer">
        
        <%- include('partials/footer.ejs') %>

    </footer>

</main>

</body>
</html>