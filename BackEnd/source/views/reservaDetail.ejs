<ul class="ul-reserva-detail">

  <!-- INFO GENERAL DE LA RESERVA -->
  <li class="compra">

    <p><strong>Estado:</strong> 
    </p>

    <p><strong>Fecha de Reserva:</strong> 
      <%= reserva.fecha_reserva ? (reserva.fecha_reserva.toLocaleString ? reserva.fecha_reserva.toLocaleString() : reserva.fecha_reserva) : 'No disponible' %>
    </p>
  </li>

  <!-- DETALLE DE SERVICIOS -->
  <% detalleReserva.forEach(function(detalle, index) { %>
    <li class="compra" aria-labelledby="servicio-nombre-<%= index %>">

      <p><strong>Servicio:</strong> 
        <span id="servicio-nombre-<%= index %>">
          <%= detalle.servicio %>
        </span>
      </p>

      <p><strong>Descripción:</strong> 
        <%= detalle.descripcion ? detalle.descripcion : 'Sin descripción' %>
      </p>

      <p><strong>Duración:</strong> 
        <%= detalle.duracion ? detalle.duracion + ' min' : 'No especificada' %>
      </p>

      <p><strong>Precio:</strong> 
        $<%= detalle.precio ? detalle.precio : '0' %>
      </p>

      <p><strong>Subtotal:</strong> 
        $<%= detalle.precio ? detalle.precio : '0' %>
      </p>

    </li>
  <% }) %>

</ul>

<!-- TOTAL -->
<div class="compra" style="background:#e2e8f0;">
  <p>
    <strong>Total de la reserva:</strong> 
    $<%= reserva.total ? reserva.total : '0' %>
  </p>
</div>